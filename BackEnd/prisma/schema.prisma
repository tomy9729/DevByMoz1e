generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdventureIslandPeriod {
  weekday
  weekendMorning
  weekendAfternoon
}

model AdventureIsland {
  id              String                @id @default(cuid())
  lostArkDate     String
  period          AdventureIslandPeriod
  categoryName    String
  contentsName    String
  shortName       String
  sourceType      String
  sourceKey       String?
  rewardName      String?
  rewardShortName String?
  rewardIconUrl   String?
  contentIconUrl  String?
  contentImageUrl String?
  startTime       String
  rawData         Json
  collectedAt     DateTime
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([lostArkDate, period, contentsName])
  @@index([lostArkDate, period])
  @@index([sourceType, sourceKey, lostArkDate, period])
}

model AdventureIslandTest {
  id              String                @id @default(cuid())
  sourceKey       String
  lostArkDate     String
  period          AdventureIslandPeriod
  categoryName    String
  contentsName    String
  shortName       String
  rewardName      String?
  rewardShortName String?
  rewardIconUrl   String?
  contentIconUrl  String?
  contentImageUrl String?
  startTime       String
  rawData         Json
  collectedAt     DateTime
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([sourceKey, lostArkDate, period, contentsName])
  @@index([sourceKey, lostArkDate, period])
}

model LostArkNotice {
  id          String   @id @default(cuid())
  title       String
  noticeDate  DateTime
  link        String   @unique
  type        String
  rawData     Json
  collectedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([noticeDate, type])
}

model BotAlarmSetting {
  key       String   @id
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model BotAlarmTarget {
  id          String   @id @default(cuid())
  room        String   @unique
  packageName String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
}

model BotAlarmDelivery {
  id          String   @id @default(cuid())
  alarmType   String
  scheduleKey String
  status      String
  message     String?
  errorReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([alarmType, scheduleKey])
  @@index([status, createdAt])
}

model CharacterInfo {
  characterName String   @id
  serverName    String?
  className     String?
  itemLevel     String?
  rosterLevel   Int?
  guildName     String?
  pvpInfo       Json
  combatInfo    Json
  equipment     Json
  accessories   Json     @default("[]")
  abilityStone  Json     @default("null")
  gems          Json
  cards         Json
  engravings    Json
  bracelet      Json
  skills        Json     @default("[]")
  arkPassive    Json     @default("{}")
  avatars       Json
  profile       Json
  collectibles  Json
  arkGrid       Json     @default("{}")
  other         Json
  rawData       Json
  refreshedAt   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([serverName, characterName])
  @@index([refreshedAt])
}
