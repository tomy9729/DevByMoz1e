generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdventureIslandPeriod {
  weekday
  weekendMorning
  weekendAfternoon
}

enum CalendarOwnerType {
  personal
  group
}

enum CalendarScheduleKind {
  lostarkSystem
  user
}

enum CalendarAlarmChannel {
  kakaoDirect
  kakaoGroup
}

enum CalendarSourceType {
  lostark
  user
}

enum CalendarEventSourceType {
  lostark
  user
}

model AdventureIsland {
  id              String                @id @default(cuid())
  lostArkDate     String
  period          AdventureIslandPeriod
  categoryName    String
  contentsName    String
  shortName       String
  sourceType      String
  sourceKey       String?
  rewardName      String?
  rewardShortName String?
  rewardIconUrl   String?
  contentIconUrl  String?
  contentImageUrl String?
  startTime       String
  rawData         Json
  collectedAt     DateTime
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([lostArkDate, period, contentsName])
  @@index([lostArkDate, period])
  @@index([sourceType, sourceKey, lostArkDate, period])
}

model AdventureIslandTest {
  id              String                @id @default(cuid())
  sourceKey       String
  lostArkDate     String
  period          AdventureIslandPeriod
  categoryName    String
  contentsName    String
  shortName       String
  rewardName      String?
  rewardShortName String?
  rewardIconUrl   String?
  contentIconUrl  String?
  contentImageUrl String?
  startTime       String
  rawData         Json
  collectedAt     DateTime
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([sourceKey, lostArkDate, period, contentsName])
  @@index([sourceKey, lostArkDate, period])
}

model Calendar {
  id           String             @id @default(cuid())
  name         String
  defaultColor String
  isVisible    Boolean            @default(true)
  sortOrder    Int                @default(100)
  sourceType   CalendarSourceType
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  events       CalendarEvent[]

  @@unique([sourceType, name])
  @@index([isVisible, sortOrder])
}

model CalendarEvent {
  id                 String                  @id @default(cuid())
  calendarId         String
  title              String
  description        String?
  startDateTime      DateTime
  endDateTime        DateTime
  allDay             Boolean                 @default(false)
  color              String?
  sourceType         CalendarEventSourceType
  externalSourceType String?
  externalSourceId   String?
  recurrenceRule     String?
  alarmEnabled       Boolean                 @default(false)
  rawData            Json                    @default("{}")
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  calendar           Calendar                @relation(fields: [calendarId], references: [id], onDelete: Cascade)

  @@unique([sourceType, externalSourceType, externalSourceId])
  @@index([calendarId, startDateTime, endDateTime])
  @@index([sourceType, externalSourceType])
}

model LostArkNotice {
  id          String   @id @default(cuid())
  title       String
  noticeDate  DateTime
  link        String   @unique
  type        String
  rawData     Json
  collectedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([noticeDate, type])
}

model CalendarOwner {
  id                      String                           @id @default(cuid())
  type                    CalendarOwnerType
  kakaoUserKey            String?
  kakaoRoomKey            String?
  displayName             String?
  enabled                 Boolean                          @default(true)
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  lostArkScheduleSettings LostArkSchedulePreference[]
  scheduleTypeSettings    CalendarScheduleTypePreference[]
  userSchedules           UserCalendarSchedule[]
  alarms                  CalendarScheduleAlarm[]

  @@unique([type, kakaoUserKey])
  @@unique([type, kakaoRoomKey])
  @@index([enabled])
}

model LostArkSchedulePreference {
  id           String        @id @default(cuid())
  ownerId      String
  scheduleKey  String
  scheduleType String
  isVisible    Boolean       @default(true)
  alarmEnabled Boolean       @default(false)
  color        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        CalendarOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, scheduleKey])
  @@index([ownerId, scheduleType])
}

model CalendarScheduleTypePreference {
  id           String        @id @default(cuid())
  ownerId      String
  scheduleType String
  isVisible    Boolean       @default(true)
  alarmEnabled Boolean       @default(false)
  color        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  owner        CalendarOwner @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, scheduleType])
}

model UserCalendarSchedule {
  id            String                  @id @default(cuid())
  ownerId       String
  title         String
  scheduleDate  String
  startDateTime String?
  endDateTime   String?
  allDay        Boolean                 @default(true)
  description   String?
  color         String?
  isVisible     Boolean                 @default(true)
  sortOrder     Int                     @default(100)
  rawData       Json                    @default("{}")
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  owner         CalendarOwner           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  alarms        CalendarScheduleAlarm[]

  @@index([ownerId, scheduleDate])
}

model CalendarScheduleAlarm {
  id             String                @id @default(cuid())
  ownerId        String
  scheduleKind   CalendarScheduleKind
  scheduleKey    String?
  userScheduleId String?
  enabled        Boolean               @default(true)
  remindMinutes  Int                   @default(0)
  channel        CalendarAlarmChannel
  message        String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  owner          CalendarOwner         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  userSchedule   UserCalendarSchedule? @relation(fields: [userScheduleId], references: [id], onDelete: Cascade)

  @@index([ownerId, scheduleKind, scheduleKey])
  @@index([userScheduleId])
}

model BotAlarmSetting {
  key       String   @id
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model BotAlarmTarget {
  id          String   @id @default(cuid())
  room        String   @unique
  packageName String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
}

model BotAlarmDelivery {
  id          String   @id @default(cuid())
  alarmType   String
  scheduleKey String
  status      String
  message     String?
  errorReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([alarmType, scheduleKey])
  @@index([status, createdAt])
}

model CharacterInfo {
  characterName String   @id
  serverName    String?
  className     String?
  itemLevel     String?
  rosterLevel   Int?
  guildName     String?
  pvpInfo       Json
  combatInfo    Json
  equipment     Json
  accessories   Json     @default("[]")
  abilityStone  Json     @default("null")
  gems          Json
  cards         Json
  engravings    Json
  bracelet      Json
  skills        Json     @default("[]")
  arkPassive    Json     @default("{}")
  avatars       Json
  profile       Json
  collectibles  Json
  arkGrid       Json     @default("{}")
  other         Json
  rawData       Json
  refreshedAt   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([serverName, characterName])
  @@index([refreshedAt])
}
